# TODO: Transifex integration
#
# 1) Create message catalog:
#    $ pybabel extract -F pyproject.toml -o /translations/messages.pot
#    $ pybabel init -i /translations/messages.pot -d /translations -l <lang>
#    $ pybabel compile -d /translations --use-fuzzy
# 2) Ensure project has been created on Transifex under the inveniosoftware
#    organisation.
# 3) Install the transifex-client
#    $ pip install transifex-client
# 4) Push source (.pot) and translations (.po) to Transifex
#    $ tx push -s -t
# 5) Pull translations for a single language from Transifex
#    $ tx pull -l <lang>
# 6) Pull translations for all languages from Transifex
#    $ tx pull -a

[main]
host = https://www.transifex.com

[invenio.invenio-checks-messages]
file_filter = invenio_checks/translations/<lang>/LC_MESSAGES/messages.po
source_file = invenio_checks/translations/messages.pot
source_lang = en
type = PO
